# ── Vehicle ML Agent – konfiguracja ──────────────────────────
# Skopiuj ten plik jako .env i uzupełnij wartości.

# OpenAI API Key (wymagany)
OPENAI_API_KEY=sk-your-api-key-here

# Model OpenAI (domyślnie gpt-4o-mini – najtańszy i wystarczający)
OPENAI_MODEL=gpt-4o-mini

# Database URL (domyślnie SQLite w bieżącym katalogu)
# Lokalne:
DATABASE_URL=sqlite+aiosqlite:///./vehicle_database.db
# Railway z volume (mount path: /data):
# DATABASE_URL=sqlite+aiosqlite:////data/vehicle_database.db
# Railway z PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Autentykacja (pojedyncze konto dla rekruterów) ────────────
AUTH_USERNAME=recruiter
AUTH_PASSWORD=changeme
# Wygeneruj losowy klucz, np.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_DAYS=7

# ── Rate limiting ──────────────────────────────────────────────
# Format slowapi: "N/okres" (np. "30/hour", "100/day", "5/minute")
RATE_LIMIT_ASK=30/hour

# ── S3-compatible storage (RunPod, AWS S3, Cloudflare R2, etc.) ─
# Leave blank to use local file storage.
S3_ENDPOINT_URL=https://your-pod.runpod.net:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=vehicle-images
S3_REGION=us-east-1
